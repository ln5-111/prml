from __future__ import annotations

import argparse
from pathlib import Path

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error

import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout
from tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="LSTM multivariate PM2.5 forecasting")
    parser.add_argument("--csv", type=Path, required=True, help="CSV 数据路径")
    parser.add_argument("--lookback", type=int, default=24, help="使用过去多少小时预测下一小时，默认 24")
    parser.add_argument("--test_ratio", type=float, default=0.2, help="测试集比例，默认 0.2")
    parser.add_argument("--epochs", type=int, default=30, help="训练轮数，默认 30")
    parser.add_argument("--batch_size", type=int, default=64, help="批大小，默认 64")
    parser.add_argument("--output_dir", type=Path, default=Path("outputs_lstm"), help="输出目录")
    return parser.parse_args()


def set_seed(seed: int = 42) -> None:
    np.random.seed(seed)
    tf.random.set_seed(seed)


def load_and_preprocess(csv_path: Path):
    """读取并预处理数据。"""
    if not csv_path.exists():
        raise FileNotFoundError(f"找不到 CSV 文件：{csv_path}")

    df = pd.read_csv(csv_path)

    # 兼容两类常见列名：原始 Kaggle 版和已经清洗后的版本
    rename_map = {
        "pm2.5": "pollution",
        "DEWP": "dew",
        "TEMP": "temp",
        "PRES": "press",
        "cbwd": "wnd_dir",
        "Iws": "wnd_spd",
        "Is": "snow",
        "Ir": "rain",
    }
    df = df.rename(columns=rename_map)

    # 如果原始数据没有 date，而是 year/month/day/hour，就合成 date
    if "date" not in df.columns:
        time_cols = ["year", "month", "day", "hour"]
        if all(col in df.columns for col in time_cols):
            df["date"] = pd.to_datetime(df[time_cols])
        else:
            raise ValueError("数据中既没有 date 列，也没有 year/month/day/hour 四列，无法构造时间索引。")
    else:
        df["date"] = pd.to_datetime(df["date"])

    needed_cols = ["date", "pollution", "dew", "temp", "press", "wnd_dir", "wnd_spd", "snow", "rain"]
    missing = [col for col in needed_cols if col not in df.columns]
    if missing:
        raise ValueError(f"缺少必要列：{missing}")

    df = df[needed_cols].copy()
    df = df.sort_values("date").reset_index(drop=True)

    # 处理缺失值：先前向填充，再后向填充；如果仍有缺失，再删除
    df = df.ffill().bfill().dropna()

    # 风向是类别变量，用 one-hot 编码
    df = pd.get_dummies(df, columns=["wnd_dir"], drop_first=False)

    # 时间列只用于排序和画图，不作为 LSTM 特征
    dates = df["date"].copy()
    feature_df = df.drop(columns=["date"])

    # 数值归一化。这里所有 one-hot 列本来就是 0/1，归一化后仍然可用。
    feature_scaler = MinMaxScaler()
    scaled_values = feature_scaler.fit_transform(feature_df.values)
    scaled_df = pd.DataFrame(scaled_values, columns=feature_df.columns)

    # 单独给 pollution 建一个 scaler，方便把预测值反归一化回真实 PM2.5 数值
    target_scaler = MinMaxScaler()
    target_scaler.fit(feature_df[["pollution"]].values)

    return scaled_df, dates, feature_df.columns.tolist(), feature_scaler, target_scaler


def make_sequences(data: pd.DataFrame, dates: pd.Series, lookback: int):
    """
    构造监督学习序列。

    X[i] = 第 i-lookback 到 i-1 小时的所有特征
    y[i] = 第 i 小时的 pollution

    所以这是用过去 lookback 小时预测下一小时 pollution。
    """
    values = data.values.astype(np.float32)
    target_index = data.columns.get_loc("pollution")

    X, y, y_dates = [], [], []
    for i in range(lookback, len(values)):
        X.append(values[i - lookback:i, :])
        y.append(values[i, target_index])
        y_dates.append(dates.iloc[i])

    return np.array(X), np.array(y).reshape(-1, 1), pd.Series(y_dates)


def train_test_split_time(X, y, y_dates, test_ratio: float):
    """时间序列不能随机打乱，按时间顺序切分训练集和测试集。"""
    split_idx = int(len(X) * (1 - test_ratio))
    X_train, X_test = X[:split_idx], X[split_idx:]
    y_train, y_test = y[:split_idx], y[split_idx:]
    dates_train, dates_test = y_dates.iloc[:split_idx], y_dates.iloc[split_idx:]
    return X_train, X_test, y_train, y_test, dates_train, dates_test


def build_lstm_model(input_shape):
    model = Sequential([
        LSTM(64, return_sequences=True, input_shape=input_shape),
        Dropout(0.2),
        LSTM(32, return_sequences=False),
        Dropout(0.2),
        Dense(16, activation="relu"),
        Dense(1),
    ])

    model.compile(
        optimizer="adam",
        loss="mse",
        metrics=["mae"],
    )
    return model


def plot_history(history, output_dir: Path):
    plt.figure(figsize=(8, 5))
    plt.plot(history.history["loss"], label="train_loss")
    plt.plot(history.history["val_loss"], label="val_loss")
    plt.xlabel("Epoch")
    plt.ylabel("MSE Loss")
    plt.title("Training Curve")
    plt.legend()
    plt.tight_layout()
    path = output_dir / "training_curve.png"
    plt.savefig(path, dpi=150)
    plt.close()
    return path


def plot_prediction(dates, y_true, y_pred, output_dir: Path, max_points: int = 500):
    """画测试集真实值和预测值对比。为了图不太挤，默认只画前 500 个点。"""
    n = min(max_points, len(y_true))

    plt.figure(figsize=(12, 5))
    plt.plot(dates.iloc[:n], y_true[:n], label="True PM2.5")
    plt.plot(dates.iloc[:n], y_pred[:n], label="Predicted PM2.5")
    plt.xlabel("Time")
    plt.ylabel("PM2.5")
    plt.title("PM2.5 Forecasting Result")
    plt.legend()
    plt.xticks(rotation=30)
    plt.tight_layout()
    path = output_dir / "prediction_vs_true.png"
    plt.savefig(path, dpi=150)
    plt.close()
    return path


def main() -> None:
    args = parse_args()
    set_seed(42)
    args.output_dir.mkdir(parents=True, exist_ok=True)

    print("1. 读取并预处理数据...")
    scaled_df, dates, feature_names, feature_scaler, target_scaler = load_and_preprocess(args.csv)
    print(f"特征数量：{len(feature_names)}")
    print(f"特征列表：{feature_names}")

    print("2. 构造 LSTM 序列数据...")
    X, y, y_dates = make_sequences(scaled_df, dates, lookback=args.lookback)
    print(f"X shape: {X.shape}")
    print(f"y shape: {y.shape}")

    X_train, X_test, y_train, y_test, dates_train, dates_test = train_test_split_time(
        X, y, y_dates, args.test_ratio
    )

    print("3. 构建模型...")
    model = build_lstm_model(input_shape=(X_train.shape[1], X_train.shape[2]))
    model.summary()

    checkpoint_path = args.output_dir / "best_lstm_model.keras"
    callbacks = [
        EarlyStopping(monitor="val_loss", patience=5, restore_best_weights=True),
        ModelCheckpoint(checkpoint_path, monitor="val_loss", save_best_only=True),
    ]

    print("4. 开始训练...")
    history = model.fit(
        X_train,
        y_train,
        validation_split=0.2,
        epochs=args.epochs,
        batch_size=args.batch_size,
        callbacks=callbacks,
        verbose=1,
        shuffle=False,  # 时间序列建议不打乱
    )

    print("5. 测试集预测...")
    y_pred_scaled = model.predict(X_test)

    # 反归一化回真实 PM2.5 数值
    y_test_real = target_scaler.inverse_transform(y_test).reshape(-1)
    y_pred_real = target_scaler.inverse_transform(y_pred_scaled).reshape(-1)

    mae = mean_absolute_error(y_test_real, y_pred_real)
    rmse = np.sqrt(mean_squared_error(y_test_real, y_pred_real))

    print("\n===== 测试集结果 =====")
    print(f"MAE : {mae:.4f}")
    print(f"RMSE: {rmse:.4f}")

    print("6. 保存图像和结果...")
    curve_path = plot_history(history, args.output_dir)
    pred_path = plot_prediction(dates_test.reset_index(drop=True), y_test_real, y_pred_real, args.output_dir)

    result_df = pd.DataFrame({
        "date": dates_test.reset_index(drop=True),
        "true_pollution": y_test_real,
        "pred_pollution": y_pred_real,
    })
    result_csv = args.output_dir / "prediction_result.csv"
    result_df.to_csv(result_csv, index=False, encoding="utf-8-sig")

    print(f"训练曲线已保存：{curve_path}")
    print(f"预测对比图已保存：{pred_path}")
    print(f"预测结果 CSV 已保存：{result_csv}")
    print(f"最佳模型已保存：{checkpoint_path}")


if __name__ == "__main__":
    main()
